MONGODB_URL=mongodb://localhost:27017
JWT_SECRET=your-super-secret-key-change-in-prod
GEMINI_API_KEY=your-gemini-api-key-here


# Troubleshooting: If your app fails to connect to MongoDB Atlas (SSL/TLS handshake errors),
# for local development you can run the included MongoDB service and point `MONGODB_URL`
# to the local instance instead of Atlas:
#
#  1) Start a local MongoDB with Docker (repo includes `docker-compose.yml`):
#
#     docker compose up -d mongo
#
#  2) Or run with Docker directly:
#
#     docker run -d --name financewise-mongo -p 27017:27017 mongo:6.0
#
#  3) Then set `MONGODB_URL` to the local host in your environment (PowerShell example):
#
#     $env:MONGODB_URL = "mongodb://localhost:27017"
#
#  4) Restart the backend server:
#
#     uvicorn main:app --reload
#
# Note: TLS/SSL handshake errors often mean the local environment's OpenSSL or
# system CA bundle is incompatible with Atlas. Using a local MongoDB during
# development avoids Atlas TLS issues; use Atlas in production with secure creds.

